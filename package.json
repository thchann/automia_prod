{
  "name": "automia",
  "private": true,
  "workspaces": ["desktop", "mobile"],
  "scripts": {
    "dev": "npm run dev -w @automia/desktop",
    "dev:desktop": "npm run dev -w @automia/desktop",
    "dev:mobile": "npm run dev -w @automia/mobile",
    "build": "npm run build:vercel",
    "build:desktop": "npm run build -w @automia/desktop",
    "build:mobile": "npm run build -w @automia/mobile",
    "build:vercel": "npm run build:desktop && npm run build -w @automia/mobile -- --base /m/ && node scripts/copy-mobile-to-desktop.mjs",
    "preview:desktop": "npm run preview -w @automia/desktop",
    "preview:mobile": "npm run preview -w @automia/mobile",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
